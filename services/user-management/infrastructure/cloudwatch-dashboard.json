    {
      "type": "log",
      "properties": {
        "query": "SOURCE '/aws/lambda/user-profile-handler-dev'\n| fields @timestamp, @message\n| filter @message like /ERROR/\n| sort @timestamp desc\n| limit 20",
        "region": "us-east-1",
        "stacked": false,
        "title": "Recent Errors (Last 20)",
        "view": "table"
      }
    }
